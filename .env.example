# FoodDNA Agent — Environment Variables
#
# Copy this to .env and fill in your values.
# On Railway, set these via the dashboard: Settings → Variables

# ── Swiggy MCP Credentials ────────────────────────────────────────────────
# Get these from Swiggy Builders Club after application approval
SWIGGY_CLIENT_ID=your_client_id_here
AUTH_BASE_URL=https://auth.swiggy.com
# Staging: AUTH_BASE_URL=https://auth-staging.swiggy.com

# ── MCP Server URLs ───────────────────────────────────────────────────────
MCP_FOOD_URL=https://mcp.swiggy.com/food
MCP_INSTAMART_URL=https://mcp.swiggy.com/im
MCP_DINEOUT_URL=https://mcp.swiggy.com/dineout
# Staging: mcp-staging.swiggy.com/{server}

# ── OAuth Redirect URI ────────────────────────────────────────────────────
# Must match what you registered with Swiggy
# Local: http://localhost:3000/api/auth/callback
# Railway: https://your-app-name.up.railway.app/api/auth/callback
REDIRECT_URI=https://your-app-name.up.railway.app/api/auth/callback

# ── Server ────────────────────────────────────────────────────────────────
PORT=3000
